package com.example.glicocontroldavi

import retrofit2.Response
import retrofit2.http.Body
import retrofit2.http.POST

// 1. O que o aplicativo vai ENVIAR para o servidor Python
data class Medicao(
    val valor_glicose: Int,
    val momento: String
)

// 2. O que o aplicativo vai RECEBER do servidor Python
data class RespostaIA(
    val status: String,
    val IA_resposta: String
)

// 3. A rota de comunicação
interface ApiService {
    @POST("registrar")
    suspend fun enviarMedicao(@Body medicao: Medicao): Response<RespostaIA>
}